{
  "expo": {
    "name": "VITTA UP",
    "slug": "vittaup",
    "version": "1.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vittaup",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fit.vittaup.app",
      "buildNumber": "77",
      "usesAppleSignIn": true,
      "backgroundColor": "#0D0D0D",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram-stories",
          "instagram"
        ]
      }
    },
    "android": {
      "package": "fit.vittaup.app",
      "adaptiveIcon": {
        "backgroundColor": "#0D0D0D",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "backgroundColor": "#0D0D0D"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-image-picker",
      "expo-web-browser",
      "expo-notifications",
      "./plugins/withSwiftConcurrencyFix",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "fit.vittaup.app.widgets",
          "groupIdentifier": "group.fit.vittaup.app",
          "widgets": [
            {
              "name": "MetaSemanal",
              "displayName": "Meta Semanal",
              "description": "Acompanhe sua meta de corrida semanal",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      "expo-sharing",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "mapboxToken": "MAPBOX_TOKEN_PLACEHOLDER",
      "eas": {
        "projectId": "af4b0142-d6fb-4393-a5db-b9b591984053"
      }
    },
    "owner": "firezy",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/af4b0142-d6fb-4393-a5db-b9b591984053"
    }
  }
}
